{
  "manifest_version": 3,
  "name": "Coding Master → GitHub Auto Saver",
  "version": "1.0.0",
  "description": "정답 제출 시 코드를 GitHub 로그인한 사용자 계정의 aivle-codemasters에 저장합니다.",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://github.com/*",
    "https://educodegenius.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://educodegenius.com/practice/genius*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
